{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es5",
    "inlineSourceMap": true,
    "noImplicitAny": true,
    "removeComments": true,
    "preserveConstEnums": true
  },
  "formatCodeOptions": {
    "indentSize": 2,
    "tabSize": 2,
    "newLineCharacter": "\n",
    "convertTabsToSpaces": true
  },
  "compileOnSave": false,
  "buildOnSave": false,
  "atom": {
    "formatOnSave": true
  },
  "filesGlob": [
    "./src/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
