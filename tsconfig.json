{
  "compilerOptions": {
  "module": "commonjs",
    "target": "es5",
    "sourceMap": true,
    "noImplicitAny": true,
    "removeComments": true,
    "preserveConstEnums": true
  },
  "formatCodeOptions": {
    "indentSize": 2,
    "tabSize": 2,
    "newLineCharacter": "\n",
    "convertTabsToSpaces": true
  },
  "atom": {
    "formatOnSave": true
  },
  "filesGlob": [
    "typings/**/*.ts",
    "src/**/*.ts"
  ]
}
